{
    "name": "omega-mvc/omega-wp",
    "type": "wordpress-plugin",
    "version": "1.0.0",
    "description": "Task Manager description",
    "homepage": "https://omega-mvc.github.io",
    "license": "GPL-3.0+",
    "authors": [
        {
            "name": "Adriano Giovannini",
            "email": "agisoftt@gmail.com",
            "role": "Developer"
        }
    ],
    "keywords": [
        "framework",
        "MVC",
        "PHP 8.4",
        "example",
        "modern",
        "lightweight",
        "wordpress"
    ],
    "require": {
        "php": "^8.4",
        "omega-mvc/wp-framework": "^1.0.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
